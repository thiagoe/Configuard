# NetConfig Manager - Backend Environment Variables
# Copy this file to .env and update with your values

# Application
APP_NAME=NetConfig Manager
APP_VERSION=1.0.0
DEBUG=true
ENVIRONMENT=development

# Server
HOST=0.0.0.0
PORT=8000

# Database (MariaDB)
DB_HOST=localhost
DB_PORT=3306
DB_USER=configuard
DB_PASSWORD=configuard123
DB_NAME=configuard
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# JWT Authentication
# IMPORTANT: Change this in production!
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Encryption Key for credentials (32 bytes)
# IMPORTANT: Change this in production!
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
ENCRYPTION_KEY=your-32-byte-encryption-key-change-in-production

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Logging
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_RETENTION_DAYS=30

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60
